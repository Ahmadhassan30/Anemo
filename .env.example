# ==============================================================================
# LectureOS Environment Variables Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database
# ------------------------------------------------------------------------------
# PostgreSQL database connection URL (e.g. postgresql+asyncpg://lectureos:secret@postgres:5432/lectureos)
DATABASE_URL=postgresql+asyncpg://lectureos:secret@postgres:5432/lectureos
# Vector dimension size for pgvector embeddings database matching
PGVECTOR_DIM=1536

# ------------------------------------------------------------------------------
# 2. Redis
# ------------------------------------------------------------------------------
# Redis connection URL used for caching and message broker storage
REDIS_URL=redis://redis:6379/0
# Celery task broker URL
CELERY_BROKER_URL=redis://redis:6379/0
# Celery task results backend storage destination URL
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ------------------------------------------------------------------------------
# 3. AWS & Uploads (UploadThing)
# ------------------------------------------------------------------------------
# Secret token key for authenticating with UploadThing CDN storage services
UPLOADTHING_SECRET=sk_live_your_secret_here
# Identifier for the specific UploadThing application instance
UPLOADTHING_APP_ID=your_app_id_here

# ------------------------------------------------------------------------------
# 4. AI APIs & Local Models
# ------------------------------------------------------------------------------
# DeepSeek API Authentication credentials key
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Base URL endpoint matching the DeepSeek AI model endpoints
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Path location reference to the local Qwen offline model folder
QWEN_MODEL_PATH=Qwen/Qwen2.5-Coder-7B-Instruct
# SentenceTransformers model identifier used for generating text embeddings
EMBEDDING_MODEL_NAME=text-embedding-3-small
# Embedding dimensions matching vector database specifications
EMBEDDING_DIM=1536
# OpenAI Whisper speech-to-text model weight configuration size
WHISPER_MODEL_SIZE=large-v3
# Compute hardware target device specification for running models (cpu or cuda)
WHISPER_DEVICE=cpu
# Quantization compute execution type used for Whisper (e.g. float16, int8)
WHISPER_COMPUTE_TYPE=int8
# Absolute path location pointer to FFmpeg installation directory or execution executable
FFMPEG_PATH=/usr/bin/ffmpeg

# ------------------------------------------------------------------------------
# 5. YouTube
# ------------------------------------------------------------------------------
# Google API Console Project credentials ID targeting YouTube APIs
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
# Secret credentials key targeting YouTube APIs
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
# Configured redirect URI mapping for user login consent flows
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/youtube/callback
# Offline access token used to refresh credentials
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token_here

# ------------------------------------------------------------------------------
# 6. Auth
# ------------------------------------------------------------------------------
# JWT Token cryptography signing password/secret (minimum 32 characters)
JWT_SECRET=your_super_secret_api_jwt_signing_key_here
# Hashing encryption standard utilized for verifying session JWT tokens
JWT_ALGORITHM=HS256
# Token expiration duration limit in minutes
JWT_EXPIRES_MINUTES=1440
# NextAuth application server landing site routing URL matching production/localhost domain
NEXTAUTH_URL=http://localhost:3000
# NextAuth credential cookie security encryption secret
NEXTAUTH_SECRET=your_nextauth_cookie_session_secret_key_here

# ------------------------------------------------------------------------------
# 7. App Config
# ------------------------------------------------------------------------------
# Core server lifecycle environment flag (development, staging, production)
APP_ENV=development
# Logging details level threshold limit filter (debug, info, warning, error)
LOG_LEVEL=INFO
# Backend API server hostname configuration
API_HOST=0.0.0.0
# Backend API server listener port mapping
API_PORT=8000
# Public application endpoint route link URL mapping
PUBLIC_BASE_URL=http://localhost
# Allowed cross-origin resource origins
CORS_ORIGINS=["http://localhost", "http://localhost:3000"]
# Next.js environment endpoint target for fetching APIs
NEXT_PUBLIC_API_BASE_URL=http://localhost/api/v1
# Next.js environment endpoint target for SSE stream updates
NEXT_PUBLIC_SSE_BASE_URL=http://localhost/api/v1
# Low-level visual rendering quality level for Manim scripts (ql, qm, qh)
MANIM_RENDER_QUALITY=ql
# Temporary host directory folder utilized to store Manim render output sequences
MANIM_OUTPUT_DIR=/tmp/manim_output
# Server-Sent Events (SSE) keepalive signal heartbeat ping interval in seconds
SSE_PING_INTERVAL_SECONDS=15
